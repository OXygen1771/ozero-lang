// clang-format off
// NOLINTBEGIN

#pragma once

#define OZERO_VERSION "@PROJECT_VERSION@"
#define OZERO_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define OZERO_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define OZERO_VERSION_PATCH @PROJECT_VERSION_PATCH@


#cmakedefine OZERO_FORCE_ENABLE_LOGGING
#cmakedefine OZERO_FORCE_DISABLE_ASSERTIONS
#if defined(OZERO_FORCE_ENABLE_LOGGING) || defined(_DEBUG) || !defined(NDEBUG)
    #if !defined(OZERO_FORCE_DISABLE_ASSERTIONS)
        #define OZERO_ASSERTIONS_ENABLED
    #endif // !defined(OZERO_FORCE_DISABLE_ASSERTIONS)
    #define OZERO_LOG_TRACE_ENABLED
    #define OZERO_LOG_DEBUG_ENABLED
    #define OZERO_LOG_INFO_ENABLED
    #define OZERO_LOG_WARN_ENABLED
    #define OZERO_DEBUG
#endif // defined(OZERO_FORCE_ENABLE_LOGGING) || defined(_DEBUG) || !defined(NDEBUG)

#cmakedefine OZERO_FORCE_DISABLE_LOGGING
#if defined(OZERO_FORCE_DISABLE_LOGGING)
    #define OZERO_LOG_ERROR_DISABLED
    #define OZERO_LOG_FATAL_DISABLED
#endif // defined(OZERO_FORCE_DISABLE_LOGGING)

// NOLINTEND
// clang-format on
